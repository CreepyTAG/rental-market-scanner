# Copier ce fichier en .env et remplir les valeurs
# cp .env.example .env && nano .env

# ── Telegram Bot ──────────────────────────────────────────────────────────────
# Obtenir via @BotFather sur Telegram
TELEGRAM_TOKEN=

# Ton chat_id (restreint l'accès au bot)
# Pour le trouver : https://api.telegram.org/bot<TOKEN>/getUpdates après /start
TELEGRAM_CHAT_ID=

# ── Proxy résidentiel (optionnel) ─────────────────────────────────────────────
# Format : http://user:pass@host:port
# PROXY_URL=
